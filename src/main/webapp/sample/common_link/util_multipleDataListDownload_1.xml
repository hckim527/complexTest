<?xml version="1.0" encoding="UTF-8"?>
<html xmlns="http://www.w3.org/1999/xhtml"
    xmlns:ev="http://www.w3.org/2001/xml-events"
    xmlns:w2="http://www.inswave.com/websquare" xmlns:xf="http://www.w3.org/2002/xforms">
    <head>
        <w2:type>COMPONENT</w2:type>
        <w2:buildDate/>
        <w2:MSA/>
        <xf:model>
            <w2:dataCollection baseNode="map">
                <w2:dataList id="wf_dataList1" baseNode="list" repeatNode="map">
                    <w2:columnInfo>
                        <w2:column id="col_name" name="이름" dataType="text"></w2:column>
                        <w2:column id="col_dept" name="부서" dataType="text"></w2:column>
                        <w2:column id="col_age" name="나이" dataType="number"></w2:column>
                    </w2:columnInfo>
                </w2:dataList>
                <w2:dataList id="wf_dataList2" baseNode="list" repeatNode="map">
                    <w2:columnInfo>
                        <w2:column id="col_code" name="코드" dataType="text"></w2:column>
                        <w2:column id="col_product" name="상품명" dataType="text"></w2:column>
                        <w2:column id="col_price" name="가격" dataType="number"></w2:column>
                    </w2:columnInfo>
                </w2:dataList>
            </w2:dataCollection>
            <w2:workflowCollection/>
        </xf:model>
        <w2:layoutInfo/>
        <w2:publicInfo method=""/>
        <script lazy="false" type="text/javascript"><![CDATA[
scwin.onpageload = function() {
    // wframe 내부 DataList 데이터 설정
    var arr1 = [
        "최영수", "인사팀", "29",
        "한지민", "총무팀", "33",
        "오세준", "개발팀", "27"
    ];
    wf_dataList1.setData(arr1);

    var arr2 = [
        "S001", "서버", "3200000",
        "S002", "스위치", "890000",
        "S003", "라우터", "1500000"
    ];
    wf_dataList2.setData(arr2);
};
]]></script>
    </head>
    <body ev:onpageload="scwin.onpageload">
        <xf:group style="width:100%;" id="group1">
            <w2:textbox style="" id="" label="wframe 내부 DataList (wf_dataList1, wf_dataList2)" class="" escape="false"></w2:textbox>
            <w2:gridView id="wf_gridView1" dataList="data:wf_dataList1" style="width:100%;height:100px;">
                <w2:header id="header1" style="">
                    <w2:row id="row1" style="">
                        <w2:column id="hc_name" style="" inputType="text" width="100" value="이름" displayMode="label"></w2:column>
                        <w2:column id="hc_dept" style="" inputType="text" width="100" value="부서" displayMode="label"></w2:column>
                        <w2:column id="hc_age" style="" inputType="text" width="60" value="나이" displayMode="label"></w2:column>
                    </w2:row>
                </w2:header>
                <w2:gBody id="gBody1" style="">
                    <w2:row id="row2" style="">
                        <w2:column id="col_name" style="" inputType="text" width="100" displayMode="label"></w2:column>
                        <w2:column id="col_dept" style="" inputType="text" width="100" displayMode="label"></w2:column>
                        <w2:column id="col_age" style="" inputType="text" width="60" displayMode="label"></w2:column>
                    </w2:row>
                </w2:gBody>
            </w2:gridView>
            <w2:gridView id="wf_gridView2" dataList="data:wf_dataList2" style="width:100%;height:100px;margin-top:5px;">
                <w2:header id="header2" style="">
                    <w2:row id="row3" style="">
                        <w2:column id="hc_code" style="" inputType="text" width="80" value="코드" displayMode="label"></w2:column>
                        <w2:column id="hc_product" style="" inputType="text" width="150" value="상품명" displayMode="label"></w2:column>
                        <w2:column id="hc_price" style="" inputType="text" width="100" value="가격" displayMode="label"></w2:column>
                    </w2:row>
                </w2:header>
                <w2:gBody id="gBody2" style="">
                    <w2:row id="row4" style="">
                        <w2:column id="col_code" style="" inputType="text" width="80" displayMode="label"></w2:column>
                        <w2:column id="col_product" style="" inputType="text" width="150" displayMode="label"></w2:column>
                        <w2:column id="col_price" style="" inputType="text" width="100" displayMode="label"></w2:column>
                    </w2:row>
                </w2:gBody>
            </w2:gridView>
        </xf:group>
    </body>
</html>
